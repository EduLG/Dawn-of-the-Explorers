Table user {
  id varchar(36) [pk]
  username varchar [not null, unique]
  email varchar [not null, unique]
  password varchar [not null]
  party_id int [ref: > party.id, unique] // 1:1
}

Table party {
  id int [pk, increment]
  name varchar [not null]
  level int [default: 1]
  experience int [default: 0]
  rating int [default: 0]
}

Table party_character {
  id int [pk, increment]
  party_id int [not null, ref: > party.id]
  character_id int [not null, ref: > character.id]
  party_slot int [not null] // 1-4

  Indexes {
    (party_id, party_slot) [unique]
  }
}

Table character {
  id int [pk, increment]
  name varchar [not null]
  current_job_id int [ref: > job.id]
}

Table job {
  id int [pk, increment]
  name varchar [not null]
  icon varchar [not null] //route or path to icon image
}

Table equipment {
  id int [pk, increment]
  name varchar [not null]
  type enum('head', 'chest', 'primary hand', 'secondary hand', 'accesory') [not null]
  rating int [default: 0]
}

Table job_equipment {
  id int [pk, increment]
  job_id int [ref: > job.id]
  equipment_id int [ref: > equipment.id]

  Indexes {
    (job_id, equipment_id) [unique]
  }
}

Table character_equipment {
  id int [pk, increment]
  character_id int [not null, ref: > character.id]
  equipment_id int [not null, ref: > equipment.id]
  slot varchar [not null]

  Indexes {
    (character_id, slot) [unique]
  }
}
